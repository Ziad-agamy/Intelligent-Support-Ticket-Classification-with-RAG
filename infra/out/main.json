                        {
                          "name": "PGHOST",
                          "secretRef": "pghost"
                        },
                        {
                          "name": "PGPORT",
                          "value": "5432"
                        },
                        {
                          "name": "PGDATABASE",
                          "value": "postgres"
                        },
                        {
                          "name": "PGUSER",
                          "value": "postgres"
                        },
                        {
                          "name": "OLLAMA_BASE_URL",
