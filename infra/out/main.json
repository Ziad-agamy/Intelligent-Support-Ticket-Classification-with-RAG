                          "secretRef": "cohere-api-key"
                        },
                        {
                          "name": "GROQ_API_KEY",
                          "secretRef": "groq-api-key"
                        },
                        {
                          "name": "PINECONE_API_KEY",
                          "secretRef": "pinecone-api-key"
                        },
                        {
                          "name": "PINECONE_INDEX_NAME",
